{
  "expo": {
    "name": "POP",
    "slug": "pop-mobile",
    "scheme": "pop",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/app_icon_square.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lsi.pop"
    },
    "android": {
      "package": "com.lsi.pop",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/app_icon_square.png",
        "backgroundColor": "#2f63ea"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icons/app_icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
